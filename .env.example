# AI-Portal 环境变量配置
# 复制为 .env 即可使用（docker-compose 默认值可直接启动）

# JWT 密钥（默认 change-me-in-production，生产建议修改）
# JWT_SECRET=change-me-in-production

# PostgreSQL（docker-compose 默认使用内置数据库）
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_portal
DB_USER=root
DB_PASSWORD=Password123@aiportal

# 首次启动自动创建 admin 账号（默认密码 admintest，留空则不创建）
INIT_ADMIN_PASSWORD=admintest

# 从 1Panel 同步用户时的默认密码（留空则无法密码登录）
# SYNC_USER_DEFAULT_PASSWORD=

# 1Panel 网关地址（也可在管理后台配置）
PANEL_BASE_URL=

# 1Panel API 密钥
PANEL_API_KEY=

# 1Panel 请求超时（毫秒，默认 10000）
PANEL_API_TIMEOUT=10000

# 反向代理前缀，例：/ai-portal/（默认 /）
# BASE_PATH=/

# 本地非容器开发
# PORT=3002
# SERVE_STATIC=false
# STATIC_PATH=./dist
# VITE_API_URL=http://localhost:3002/api
# LOCAL_STORAGE_PATH=/data/uploads/skills
