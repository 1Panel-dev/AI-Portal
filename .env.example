# AI-Portal 环境变量配置
# 复制为 .env 即可使用（docker-compose 默认值可直接启动）

# JWT 密钥（默认 change-me-in-production，生产建议修改）
# JWT_SECRET=change-me-in-production

# PostgreSQL（docker-compose 默认使用内置数据库）
# 默认用户 root，密码 Password123@aiportal
# DB_HOST=pg.example.com  DB_PORT=5432  DB_NAME=ai_portal  DB_USER=root  DB_PASSWORD=Password123@aiportal

# 首次启动自动创建 admin 账号（留空则不创建）
# INIT_ADMIN_PASSWORD=

# 从 1Panel 同步用户时的默认密码（留空则无法密码登录）
# SYNC_USER_DEFAULT_PASSWORD=

# 1Panel 网关（也可在管理后台配置，DB 配置优先级更高）
PANEL_BASE_URL=
PANEL_API_KEY=
PANEL_API_TIMEOUT=10000

# 反向代理前缀（例：/ai-portal/，默认 /）
# BASE_PATH=/

# 本地非容器开发
# PORT=3002  SERVE_STATIC=false  STATIC_PATH=./dist
# VITE_API_URL=http://localhost:3002/api
# LOCAL_STORAGE_PATH=/data/uploads/skills
