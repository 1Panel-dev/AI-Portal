# AI-Portal 环境变量配置
# 复制为 .env 即可使用（docker-compose 默认值可直接启动）

# JWT 密钥
# 默认 change-me-in-production，生产环境建议改为随机字符串
# JWT_SECRET=change-me-in-production

# 数据库主机地址（docker-compose 默认使用内置 PostgreSQL）
# DB_HOST=pg.example.com

# 数据库端口
# DB_PORT=5432

# 数据库名称
# DB_NAME=ai_portal

# 数据库用户（默认 root）
# DB_USER=root

# 数据库密码（默认 Password123@aiportal）
# DB_PASSWORD=Password123@aiportal

# 首次启动自动创建 admin 账号（留空则不创建）
# INIT_ADMIN_PASSWORD=

# 从 1Panel 同步用户时的默认密码（留空则无法密码登录）
# SYNC_USER_DEFAULT_PASSWORD=

# 1Panel 网关地址（也可在管理后台配置）
PANEL_BASE_URL=

# 1Panel API 密钥
PANEL_API_KEY=

# 1Panel 请求超时（毫秒，默认 10000）
PANEL_API_TIMEOUT=10000

# 反向代理前缀，例：/ai-portal/（默认 /）
# BASE_PATH=/

# 本地非容器开发
# PORT=3002
# SERVE_STATIC=false
# STATIC_PATH=./dist
# VITE_API_URL=http://localhost:3002/api
# LOCAL_STORAGE_PATH=/data/uploads/skills
