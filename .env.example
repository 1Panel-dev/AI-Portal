# AI-Portal 环境变量配置
# 复制为 .env 并填入实际值
#
# 两类用途：
#   1. docker-compose 部署：仅需「容器部署」段
#   2. 本地非容器开发：需要「容器部署」 + 「本地开发」两段

# ==========================================================
# 容器部署（docker-compose）
# ==========================================================

# ----- JWT 密钥（可选，默认 change-me-in-production）-----
# 生产环境建议改为随机字符串：openssl rand -hex 32
# JWT_SECRET=change-me-in-production

# ----- 数据库（可选，docker-compose 默认使用内置 PostgreSQL）-----
# 默认用户 root，密码 Password123@aiportal
# 如需外部数据库，取消注释并填入实际值
# DB_HOST=pg.example.com
# DB_PORT=5432
# DB_NAME=ai_portal
# DB_USER=root
# DB_PASSWORD=Password123@aiportal

# ----- 可选：默认管理员 -----
# 留空：首次启动不创建管理员，需后续手动创建
# 设值（≥8 位）：首次启动创建 admin/<此值>，登录后请立即改密
# INIT_ADMIN_PASSWORD=

# ----- 可选：从 1Panel 同步用户时的默认密码 -----
# 管理员在管理后台执行"同步用户"时，新用户会用此密码创建
# 留空则创建的用户无法密码登录（只能通过 OAuth 等方式登录）
# SYNC_USER_DEFAULT_PASSWORD=

# ----- 可选：1Panel 网关（也可登管理后台再配，DB 配置优先级更高）-----
PANEL_BASE_URL=
PANEL_API_KEY=
PANEL_API_TIMEOUT=10000

# ----- 可选：反向代理前缀 -----
# 当通过 nginx 反代且加了 location 前缀时配置
# 例:nginx 配 location /ai-portal/ { proxy_pass http://127.0.0.1:3000/; },则设
# BASE_PATH=/ai-portal/
# 必须以 / 开头并以 / 结尾。默认 / 表示无前缀。修改后重启容器生效
# BASE_PATH=/

# ==========================================================
# 本地非容器开发（仅 npm run dev / node server/index.js 时需要）
# 容器部署可忽略下面所有项
# ==========================================================

# 后端端口
# PORT=3002

# 是否由后端托管 dist 静态文件
# SERVE_STATIC=false
# STATIC_PATH=./dist

# 前端 dev 时调用的 API base（vite build 时会被 Dockerfile 覆盖为 /api）
# VITE_API_URL=http://localhost:3002/api

# 自定义本地存储路径（容器场景已固定为 /app/data/uploads/skills）
# LOCAL_STORAGE_PATH=/data/uploads/skills
